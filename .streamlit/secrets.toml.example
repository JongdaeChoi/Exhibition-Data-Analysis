# Copy these names into Streamlit Cloud Secrets or a local
# .streamlit/secrets.toml file. Never commit real values.
OPENAI_API_KEY = "replace-with-existing-openai-key"
GEMINI_API_KEY = "replace-with-gemini-key"

# Private Supabase Storage bucket owned by the developer account.
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY = "replace-with-service-role-key"
SUPABASE_STORAGE_BUCKET = "streamlit-test-files"
SUPABASE_STORAGE_PREFIX = "streamlit-default-test-file"
